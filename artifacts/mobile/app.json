{
  "expo": {
    "name": "Gundruk",
    "slug": "gundruk",
    "version": "1.0.2",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/c60fdd9d-6ced-4370-86de-24d16864e642"
    },
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "vibe",
    "userInterfaceStyle": "dark",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.prakasharyal.gundruk",
      "buildNumber": "16",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Vibe uses your camera to take photos and videos for posts.",
        "NSPhotoLibraryUsageDescription": "Vibe accesses your photo library to share images.",
        "NSPhotoLibraryAddUsageDescription": "Vibe saves media to your photo library.",
        "NSLocationWhenInUseUsageDescription": "Vibe uses your location to find nearby Vibers.",
        "NSContactsUsageDescription": "Vibe uses your contacts to help you find friends on the app.",
        "NSMicrophoneUsageDescription": "Vibe uses your microphone for live streams and video posts.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleURLTypes": [
          {
            "CFBundleURLSchemes": [
              "com.googleusercontent.apps.375944530592-o2jngbbb3otgnhkhn8ohv28s1gd9c0eo"
            ]
          }
        ]
      },
      "appleTeamId": "FDHAR55857"
    },
    "android": {
      "package": "com.prakasharyal.gundruk",
      "versionCode": 15,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.READ_CONTACTS",
        "android.permission.WRITE_CONTACTS",
        "android.permission.INTERNET",
        "android.permission.VIBRATE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "favicon": "./assets/images/icon.png",
      "bundler": "metro"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/Ionicons.ttf",
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/MaterialIcons.ttf",
            "./node_modules/@expo/vector-icons/build/vendor/react-native-vector-icons/Fonts/FontAwesome.ttf"
          ]
        }
      ],
      "expo-web-browser",
      [
        "expo-image-picker",
        {
          "photosPermission": "Vibe accesses your photos to share them.",
          "cameraPermission": "Vibe uses your camera to take photos and videos."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Vibe uses your location to find nearby Vibers."
        }
      ],
      [
        "expo-contacts",
        {
          "contactsPermission": "Vibe uses your contacts to help you find friends."
        }
      ],
      [
        "expo-av",
        {
          "microphonePermission": "Vibe uses your microphone for live streams and video posts."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Gundruk uses your camera to take photos and videos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "eas": {
        "projectId": "c60fdd9d-6ced-4370-86de-24d16864e642"
      },
      "googleWebClientId": "375944530592-m00jil1hf5ppqq02mnfgrgiaen3f2a8s.apps.googleusercontent.com",
      "googleIosClientId": "375944530592-o2jngbbb3otgnhkhn8ohv28s1gd9c0eo.apps.googleusercontent.com"
